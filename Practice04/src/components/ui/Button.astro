---
import { cn } from '@lib/cn';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { href, variant = 'primary', class: className } = Astro.props;

const base = 'inline-flex items-center rounded-md px-4 py-2 text-sm font-medium transition';
const styles = {
  primary: 'bg-gray-900 text-white hover:bg-gray-800',
  secondary: 'border border-gray-300 text-gray-900 hover:bg-gray-50',
};

const classes = cn(base, styles[variant], className);
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type="button" class={classes}>
      <slot />
    </button>
  )
}
