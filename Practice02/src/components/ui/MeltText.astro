---
interface Props {
  text: string;
  stagger?: number;
  duration?: number;
  fontSize?: string;
}

const { text, stagger = 0.06, duration = 1.2, fontSize = 'text-80' } = Astro.props;
---

<div
  class="melt-text text-blue inline-flex cursor-pointer overflow-visible select-none"
  data-stagger={stagger}
  data-duration={duration}
>
  {
    [...text].map((char) => (
      <span class={`melt-char inline-block leading-none font-semibold ${fontSize}`}>
        {char === ' ' ? '\u00A0' : char}
      </span>
    ))
  }
</div>

<script>
  import { gsap } from 'gsap';

  document.querySelectorAll<HTMLElement>('.melt-text').forEach((wrapper) => {
    const duration = Number(wrapper.dataset.duration ?? 1.2);
    const stagger = Number(wrapper.dataset.stagger ?? 0.06);
    const chars = wrapper.querySelectorAll<HTMLElement>('.melt-char');
    let melted = false;

    wrapper.addEventListener('mouseenter', () => {
      if (melted) return;
      melted = true;

      wrapper.classList.remove('cursor-pointer');
      wrapper.classList.add('cursor-default');

      gsap.to(chars, {
        scaleY: 0,
        scaleX: () => gsap.utils.random(1.25, 1.45),
        skewX: () => gsap.utils.random(-10, 10),
        y: () => gsap.utils.random(65, 85),
        opacity: 0,
        filter: 'blur(14px)',
        duration,
        stagger: { each: stagger, from: 'start' },
        ease: 'power3.in',
        transformOrigin: 'center bottom',
      });
    });
  });
</script>
